<Window x:Class="Malie.Windows.MeshyModelViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        mc:Ignorable="d"
        Title="Meshy Cached Model Viewer"
        Height="700"
        Width="1450"
        MinHeight="520"
        MinWidth="1100"
        Background="#090E1A"
        Foreground="#E2E8F0"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <SolidColorBrush x:Key="SurfaceBgBrush" Color="#090E1A" />
        <SolidColorBrush x:Key="SurfaceCardBrush" Color="#12192A" />
        <SolidColorBrush x:Key="SurfaceCardAltBrush" Color="#161F33" />
        <SolidColorBrush x:Key="SurfaceBorderBrush" Color="#2B3650" />
        <SolidColorBrush x:Key="SurfaceMutedBrush" Color="#96A3BD" />
        <SolidColorBrush x:Key="PrimaryBrush" Color="#4F8BFF" />
        <SolidColorBrush x:Key="PrimaryHoverBrush" Color="#6EA1FF" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E2E8F0" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="#EAF0FF" />
            <Setter Property="Background" Value="#24304A" />
            <Setter Property="BorderBrush" Value="#3A4A6B" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2E3E5F" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#21314D" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="30" />
            <Setter Property="MinWidth" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontFamily" Value="Segoe Fluent Icons" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="Normal" />
        </Style>

        <Style x:Key="PrimaryIconButtonStyle" TargetType="Button" BasedOn="{StaticResource IconButtonStyle}">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource PrimaryHoverBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryHoverBrush}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#3C73DE" />
                    <Setter Property="BorderBrush" Value="#3C73DE" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource PrimaryHoverBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryHoverBrush}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#3C73DE" />
                    <Setter Property="BorderBrush" Value="#3C73DE" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="Foreground" Value="#E2E8F0" />
            <Setter Property="Background" Value="{StaticResource SurfaceCardAltBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource SurfaceBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{StaticResource SurfaceCardAltBrush}" />
            <Setter Property="Foreground" Value="#E2E8F0" />
            <Setter Property="BorderBrush" Value="{StaticResource SurfaceBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="RowBackground" Value="#161F33" />
            <Setter Property="AlternatingRowBackground" Value="#132039" />
            <Setter Property="HorizontalGridLinesBrush" Value="#22304A" />
            <Setter Property="VerticalGridLinesBrush" Value="#22304A" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="ColumnHeaderHeight" Value="36" />
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#1A2540" />
            <Setter Property="Foreground" Value="#DDE6FF" />
            <Setter Property="BorderBrush" Value="#2B3650" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Foreground" Value="#E2E8F0" />
            <Setter Property="BorderBrush" Value="#22304A" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#2D426D" />
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#26395E" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Foreground" Value="#E2E8F0" />
        </Style>
    </Window.Resources>

    <Grid Margin="14" Background="{StaticResource SurfaceBgBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="860" MinWidth="800" />
            <ColumnDefinition Width="10" />
            <ColumnDefinition Width="*" MinWidth="430" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Column="0" Grid.Row="0" Grid.RowSpan="3" Margin="0,0,10,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    CornerRadius="12"
                    Background="{StaticResource SurfaceCardBrush}"
                    BorderBrush="{StaticResource SurfaceBorderBrush}"
                    BorderThickness="1"
                    Padding="12"
                    Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock FontWeight="SemiBold" FontSize="17" Text="Cached Meshy Models" />
                    <TextBlock Margin="0,2,0,10"
                               FontSize="12"
                               Foreground="{StaticResource SurfaceMutedBrush}"
                               Text="Manage cached models, queue POIs, and preview generated GLBs." />

                    <DockPanel Margin="0,0,0,8" LastChildFill="False">
                        <Button Width="108"
                                Content="Refresh List"
                                ToolTip="Reload cached Meshy models and POI list."
                                Click="OnRefreshListClick" />
                        <Button Margin="8,0,0,0"
                                Width="108"
                                Content="Import GLB"
                                ToolTip="Import a local GLB into the Meshy cache."
                                Click="OnImportGlbClick" />
                        <Button Margin="8,0,0,0"
                                Width="120"
                                Content="Cancel Queue"
                                ToolTip="Cancel pending Meshy queue operations."
                                Click="OnCancelQueueClick" />
                    </DockPanel>

                    <TextBlock x:Name="QueueStatusTextBlock"
                               Margin="0,0,0,8"
                               FontSize="11"
                               Foreground="{StaticResource SurfaceMutedBrush}"
                               Text="Queue idle." />

                    <TextBlock Margin="0,2,0,4" Text="Rotate models every (minutes, 0 = disabled)" />
                    <DockPanel Margin="0,0,0,8" LastChildFill="False">
                        <TextBox x:Name="RotationMinutesTextBox"
                                 Width="110"
                                 VerticalContentAlignment="Center" />
                        <Button Margin="8,0,0,0"
                                Width="74"
                                Content="Apply"
                                Style="{StaticResource PrimaryButtonStyle}"
                                ToolTip="Apply rotation settings for cached model cycling."
                                Click="OnApplyViewerSettingsClick" />
                    </DockPanel>

                    <TextBlock Margin="0,2,0,4" Text="Custom Meshy prompt (max 800 chars)" />
                    <TextBox x:Name="CustomPromptTextBox"
                             Height="96"
                             Margin="0,0,0,4"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             TextWrapping="Wrap"
                             MaxLength="800"
                             TextChanged="OnCustomPromptTextChanged"
                             PreviewTextInput="OnCustomPromptPreviewTextInput"
                             DataObject.Pasting="OnCustomPromptPaste" />

                    <DockPanel Margin="0,0,0,8" LastChildFill="False">
                        <TextBlock x:Name="CustomPromptCountTextBlock"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource SurfaceMutedBrush}"
                                   Text="0 / 800" />
                        <Button x:Name="SubmitCustomPromptButton"
                                Margin="8,0,0,0"
                                Width="130"
                                Content="Submit Prompt"
                                Style="{StaticResource PrimaryButtonStyle}"
                                ToolTip="Send custom prompt to Meshy for generation."
                                Click="OnSubmitCustomPromptClick" />
                    </DockPanel>

                    <TextBlock x:Name="CustomPromptLimitTextBlock"
                               Margin="0,0,0,0"
                               FontSize="11"
                               Foreground="#F27D93"
                               Text=""
                               Visibility="Collapsed" />
                </StackPanel>
            </Border>

            <Border Grid.Row="1"
                    CornerRadius="12"
                    Background="{StaticResource SurfaceCardBrush}"
                    BorderBrush="{StaticResource SurfaceBorderBrush}"
                    BorderThickness="1"
                    Padding="8">
                <DataGrid x:Name="ModelTableDataGrid"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          CanUserResizeRows="False"
                          IsReadOnly="False"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          CellEditEnding="OnModelTableCellEditEnding"
                          SelectionChanged="OnModelTableSelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="POI Name"
                                            Width="2.1*"
                                            Binding="{Binding PoiName, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                        <DataGridTextColumn Header="Model File"
                                            Width="1.45*"
                                            IsReadOnly="True"
                                            Binding="{Binding ModelFileName}" />
                        <DataGridTemplateColumn Header="Status" Width="1.5*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Padding="8,3"
                                            CornerRadius="6"
                                            Background="{Binding StatusBackgroundBrush}"
                                            BorderBrush="{Binding StatusBorderBrush}"
                                            BorderThickness="1">
                                        <TextBlock Text="{Binding StatusText}"
                                                   Foreground="{Binding StatusForegroundBrush}"
                                                   FontWeight="SemiBold" />
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Action" Width="1.5*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Margin="0,0,6,0"
                                                Content="&#xE710;"
                                                Style="{StaticResource IconButtonStyle}"
                                                ToolTip="Add this POI to the Meshy download queue."
                                                IsEnabled="{Binding CanQueue}"
                                                Click="OnQueueModelClick" />
                                        <Button Content="&#xE896;"
                                                Style="{StaticResource PrimaryIconButtonStyle}"
                                                ToolTip="Download this POI model from Meshy immediately."
                                                IsEnabled="{Binding CanDownloadNow}"
                                                Click="OnDownloadNowClick" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Delete" Width="1.0*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="&#xE74D;"
                                            Style="{StaticResource IconButtonStyle}"
                                            ToolTip="Delete this cached model."
                                            IsEnabled="{Binding CanDelete}"
                                            Click="OnDeleteModelClick" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <Border Grid.Row="2"
                    Margin="0,10,0,0"
                    CornerRadius="10"
                    Background="{StaticResource SurfaceCardBrush}"
                    BorderBrush="{StaticResource SurfaceBorderBrush}"
                    BorderThickness="1"
                    Padding="10,8">
                <TextBlock x:Name="SelectedModelPathTextBlock"
                           TextWrapping="Wrap"
                           FontSize="11"
                           Foreground="{StaticResource SurfaceMutedBrush}"
                           Text="Select a model to preview." />
            </Border>
        </Grid>

        <GridSplitter Grid.Column="1"
                      Grid.Row="0"
                      Grid.RowSpan="3"
                      Width="10"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      ResizeBehavior="PreviousAndNext"
                      ResizeDirection="Columns"
                      ShowsPreview="True"
                      Background="#273445" />

        <Border Grid.Column="2"
                Grid.Row="0"
                Grid.RowSpan="2"
                CornerRadius="12"
                BorderBrush="{StaticResource SurfaceBorderBrush}"
                BorderThickness="1"
                Background="#0E1526"
                Padding="4">
            <wv2:WebView2 x:Name="ViewerWebView" />
        </Border>

        <Border Grid.Column="2"
                Grid.Row="2"
                Margin="0,10,0,0"
                CornerRadius="10"
                Background="{StaticResource SurfaceCardBrush}"
                BorderBrush="{StaticResource SurfaceBorderBrush}"
                BorderThickness="1"
                Padding="10,8">
            <TextBlock Foreground="{StaticResource SurfaceMutedBrush}"
                       Text="Viewer supports GLB/GLTF files from Meshy cache." />
        </Border>
    </Grid>
</Window>
